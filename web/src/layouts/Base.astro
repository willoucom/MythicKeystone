---
import '../styles/main.scss';
import { getImage } from 'astro:assets';
import logoSrc from '../assets/MythicDungeonNotes.png';

type Lang = 'en' | 'fr';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  /** Path WITHOUT leading lang prefix and trailing slash (e.g. "" for index, "AA" for guide). */
  altPath: string;
  /** Optional JSON-LD structured data (Article, BreadcrumbList, etc.) — emitted as <script type="application/ld+json">. */
  jsonLd?: object | object[];
}

const { title, description, lang, altPath, jsonLd } = Astro.props;
const SITE = Astro.site!.href.replace(/\/$/, '');
const base = import.meta.env.BASE_URL;

// Canonical URL for the current page (absolute).
const canonical = `${SITE}${base}${lang}/${altPath ? altPath + '/' : ''}`;

// Per-locale alternate URLs for hreflang.
const alternates: Array<{ hreflang: string; href: string }> = [
  { hreflang: 'en', href: `${SITE}${base}en/${altPath ? altPath + '/' : ''}` },
  { hreflang: 'fr', href: `${SITE}${base}fr/${altPath ? altPath + '/' : ''}` },
  // x-default — the default locale's URL.
  { hreflang: 'x-default', href: `${SITE}${base}en/${altPath ? altPath + '/' : ''}` },
];

// Open Graph image — derived from the addon logo, sized for social previews.
// 600x600 stays sharp on Twitter/Discord cards while remaining lightweight.
const ogImage = await getImage({
  src: logoSrc,
  width: 600,
  height: 600,
  format: 'webp',
});
const ogImageUrl = `${SITE}${ogImage.src}`;

const ogLocale = lang === 'fr' ? 'fr_FR' : 'en_US';
const ogLocaleAlternate = lang === 'fr' ? 'en_US' : 'fr_FR';
const jsonLdArr = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonical} />
    {alternates.map(a => (
      <link rel="alternate" hreflang={a.hreflang} href={a.href} />
    ))}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Mythic Dungeon Notes" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="600" />
    <meta property="og:image:height" content="600" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlternate} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {jsonLdArr.map(data => (
      <script type="application/ld+json" set:html={JSON.stringify(data)} />
    ))}

    <script is:inline>
      // Must execute BEFORE power.js so the config is read.
      // is:inline prevents Astro from bundling this as a deferred module.
      var whTooltips = { colorLinks: true, iconizeLinks: true, renameLinks: true };
    </script>
    <script is:inline async src="https://wow.zamimg.com/widgets/power.js"></script>
    <!-- GoatCounter analytics (cookieless, GDPR-friendly, auto-skips localhost) -->
    <script is:inline data-goatcounter="https://mythickeystone.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
  </head>
  <body>
    <slot />
  </body>
</html>
